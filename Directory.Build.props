<Project>
  <PropertyGroup>
    <VersionPrefix>0.1.0</VersionPrefix>
    <Authors>AuthNet Contributors</Authors>
    <Company>AuthNet</Company>
    <Product>AuthNet</Product>
    <RepositoryType>git</RepositoryType>
    <PackageTags>auth;identity;aspnetcore;razor-pages;postgresql</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageReleaseNotes>Initial package-readiness build for AuthNet MVP account UI, Identity integration, PostgreSQL persistence, and generic OpenID Connect support.</PackageReleaseNotes>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageOutputPath>$(MSBuildThisFileDirectory)artifacts\packages</PackageOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <None Include="$(MSBuildThisFileDirectory)README.md" Pack="true" PackagePath="" />
  </ItemGroup>
</Project>
