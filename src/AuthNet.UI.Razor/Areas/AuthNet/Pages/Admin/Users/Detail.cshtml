@page
@model AuthNetRazor.Areas.AuthNet.Pages.Admin.Users.DetailModel
@{
    ViewData["Title"] = "User details";
}

<partial name="_AuthNetBrand" />

<h1>User details</h1>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success">@Model.StatusMessage</div>
}

<dl>
    <dt>Email</dt>
    <dd>@Model.UserDetail.Email</dd>
    <dt>Username</dt>
    <dd>@Model.UserDetail.UserName</dd>
    <dt>Display name</dt>
    <dd>@Model.UserDetail.DisplayName</dd>
    <dt>Phone number</dt>
    <dd>@Model.UserDetail.PhoneNumber</dd>
    <dt>Email confirmed</dt>
    <dd>@(Model.UserDetail.EmailConfirmed ? "Yes" : "No")</dd>
    <dt>Locked out</dt>
    <dd>@(Model.UserDetail.IsLockedOut ? "Yes" : "No")</dd>
    <dt>Access failed count</dt>
    <dd>@Model.UserDetail.AccessFailedCount</dd>
    <dt>External logins</dt>
    <dd>@Model.UserDetail.ExternalLoginCount</dd>
    <dt>Roles</dt>
    <dd>@(Model.UserDetail.Roles.Count == 0 ? "None" : string.Join(", ", Model.UserDetail.Roles))</dd>
    <dt>Administrator access</dt>
    <dd>@(Model.UserDetail.IsAdministrator ? "Granted" : "Not granted")</dd>
</dl>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<h2>Administrator access</h2>

<form method="post" class="mb-2">
    @if (Model.UserDetail.IsAdministrator)
    {
        <button asp-page-handler="RemoveAdministrator" class="btn btn-outline-danger">Remove administrator</button>
    }
    else
    {
        <button asp-page-handler="GrantAdministrator" class="btn btn-outline-primary">Grant administrator</button>
    }
</form>

<h2>Role assignment</h2>

@if (Model.UserDetail.Roles.Count == 0)
{
    <p>No roles assigned.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Role</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var role in Model.UserDetail.Roles)
            {
                <tr>
                    <td>@role</td>
                    <td>
                        <form method="post" asp-page-handler="RemoveRole" asp-route-roleName="@role">
                            <button type="submit" class="btn btn-outline-danger btn-sm">Remove</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (Model.AvailableRoles.Count > 0)
{
    <form method="post" asp-page-handler="AddRole" class="mb-2">
        <div class="mb-3">
            <label asp-for="Input.RoleName" class="form-label">Add role</label>
            <select asp-for="Input.RoleName" class="form-select">
                @foreach (var role in Model.AvailableRoles)
                {
                    <option value="@role">@role</option>
                }
            </select>
            <span asp-validation-for="Input.RoleName" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary">Add role</button>
    </form>
}

<form method="post" class="mb-2">
    <button asp-page-handler="ConfirmEmail" class="btn btn-outline-primary">Confirm email</button>
    <button asp-page-handler="UnconfirmEmail" class="btn btn-outline-secondary">Unconfirm email</button>
    <button asp-page-handler="Lock" class="btn btn-outline-danger">Lock user</button>
    <button asp-page-handler="Unlock" class="btn btn-outline-success">Unlock user</button>
    <button asp-page-handler="ResetAccessFailedCount" class="btn btn-outline-secondary">Reset access failures</button>
</form>

<p><a asp-page="./Index">Back to users</a></p>
