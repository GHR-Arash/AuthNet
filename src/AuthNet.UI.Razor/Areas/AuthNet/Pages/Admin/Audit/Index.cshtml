@page
@model AuthNetRazor.Areas.AuthNet.Pages.Admin.Audit.IndexModel
@{
    ViewData["Title"] = "Audit events";
}

<partial name="_AuthNetBrand" />

<h1>Audit events</h1>

<form method="get" class="mb-3">
    <div class="row g-3">
        <div class="col-md-3">
            <label asp-for="Action" class="form-label"></label>
            <input asp-for="Action" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Actor" class="form-label"></label>
            <input asp-for="Actor" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Target" class="form-label"></label>
            <input asp-for="Target" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="From" class="form-label"></label>
            <input asp-for="From" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="To" class="form-label"></label>
            <input asp-for="To" class="form-control" />
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Filter</button>
        <a asp-page="./Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>Time</th>
            <th>Action</th>
            <th>Outcome</th>
            <th>Actor</th>
            <th>Target</th>
            <th>Metadata</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Events)
        {
            <tr>
                <td>@item.CreatedAtUtc.ToString("u")</td>
                <td>@item.Action</td>
                <td>@item.Outcome</td>
                <td>@item.Actor</td>
                <td>@item.Target</td>
                <td>@item.Metadata</td>
            </tr>
        }
    </tbody>
</table>

@if (Model.Events.Count == 0)
{
    <p>No audit events found.</p>
}
