@page
@model AuthNetRazor.Areas.AuthNet.Pages.Admin.Invitations.CreateModel
@{
    ViewData["Title"] = "New invitation";
}

<partial name="_AuthNetBrand" />

<h1>New invitation</h1>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Input.Email" class="form-label"></label>
        <input asp-for="Input.Email" class="form-control" autocomplete="email" />
        <span asp-validation-for="Input.Email" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Send invitation</button>
    <a asp-page="./Index" class="btn btn-outline-secondary">Cancel</a>
</form>

<partial name="_ValidationScriptsPartial" />
