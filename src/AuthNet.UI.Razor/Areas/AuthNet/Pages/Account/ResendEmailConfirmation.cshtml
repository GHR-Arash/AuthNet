@page
@model AuthNetRazor.Areas.AuthNet.Pages.Account.ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Resend confirmation email";
}

<partial name="_AuthNetBrand" />

<h1>Resend confirmation email</h1>

@if (Model.Sent)
{
    <div class="alert alert-info">
        If the email address belongs to an unconfirmed account, a confirmation message has been sent.
    </div>
}

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Input.Email" class="form-label"></label>
        <input asp-for="Input.Email" class="form-control" autocomplete="email" />
        <span asp-validation-for="Input.Email" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Send confirmation email</button>
</form>

<p class="mt-3"><a asp-page="./Login">Back to sign in</a></p>

<partial name="_ValidationScriptsPartial" />
