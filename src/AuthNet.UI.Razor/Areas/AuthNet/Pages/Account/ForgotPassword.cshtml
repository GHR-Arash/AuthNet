@page
@model AuthNetRazor.Areas.AuthNet.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot password";
}

<h1>Forgot password</h1>

@if (Model.Sent)
{
    <div class="alert alert-info">If the account exists and is confirmed, password reset instructions have been sent.</div>
}

<form method="post">
    <div class="mb-3">
        <label asp-for="Input.Email" class="form-label"></label>
        <input asp-for="Input.Email" class="form-control" autocomplete="email" />
        <span asp-validation-for="Input.Email" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Send reset link</button>
</form>

<partial name="_ValidationScriptsPartial" />
