@page
@model AuthNetRazor.Areas.AuthNet.Pages.Account.LoginWithMfaModel
@{
    ViewData["Title"] = "Authenticator code";
}

<partial name="_AuthNetBrand" />

<h1>Authenticator code</h1>

<form method="post">
    <input type="hidden" asp-for="ReturnUrl" />
    <input type="hidden" asp-for="RememberMe" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Input.Code" class="form-label"></label>
        <input asp-for="Input.Code" class="form-control" autocomplete="one-time-code" />
        <span asp-validation-for="Input.Code" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Verify</button>
</form>

<p class="mt-3">
    <a asp-page="./LoginWithRecoveryCode" asp-route-returnUrl="@Model.ReturnUrl">Use a recovery code</a>
</p>

<partial name="_ValidationScriptsPartial" />
