@page
@model AuthNetRazor.Areas.AuthNet.Pages.Account.MfaSetupModel
@{
    ViewData["Title"] = "Set up authenticator app";
}

<partial name="_AuthNetBrand" />

<h1>Set up authenticator app</h1>

@if (Model.RecoveryCodes.Count > 0)
{
    <div class="alert alert-success">Multi-factor authentication is enabled. Save these recovery codes now.</div>
    <ul>
        @foreach (var code in Model.RecoveryCodes)
        {
            <li><code>@code</code></li>
        }
    </ul>
    <p><a asp-page="./Mfa">Back to MFA</a></p>
}
else
{
    <p>Use this setup key in your authenticator app:</p>
    <p><code>@Model.SharedKey</code></p>
    <p>Authenticator URI:</p>
    <p><code>@Model.AuthenticatorUri</code></p>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="mb-3">
            <label asp-for="Input.Code" class="form-label"></label>
            <input asp-for="Input.Code" class="form-control" autocomplete="one-time-code" />
            <span asp-validation-for="Input.Code" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary">Verify and enable</button>
    </form>

    <p class="mt-3"><a asp-page="./Mfa">Back to MFA</a></p>
}

<partial name="_ValidationScriptsPartial" />
