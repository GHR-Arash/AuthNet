@page
@model AuthNetRazor.Areas.AuthNet.Pages.Account.LoginWithRecoveryCodeModel
@{
    ViewData["Title"] = "Recovery code";
}

<partial name="_AuthNetBrand" />

<h1>Recovery code</h1>

<form method="post">
    <input type="hidden" asp-for="ReturnUrl" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Input.RecoveryCode" class="form-label"></label>
        <input asp-for="Input.RecoveryCode" class="form-control" autocomplete="one-time-code" />
        <span asp-validation-for="Input.RecoveryCode" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Sign in</button>
</form>

<partial name="_ValidationScriptsPartial" />
