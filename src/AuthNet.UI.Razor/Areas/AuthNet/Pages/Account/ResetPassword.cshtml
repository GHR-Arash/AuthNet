@page
@model AuthNetRazor.Areas.AuthNet.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Reset password";
}

<h1>Reset password</h1>

@if (Model.Succeeded)
{
    <div class="alert alert-success">Password reset. You can now sign in.</div>
}
else
{
    <form method="post">
        <input type="hidden" asp-for="Input.Code" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="mb-3">
            <label asp-for="Input.Email" class="form-label"></label>
            <input asp-for="Input.Email" class="form-control" autocomplete="email" />
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Input.Password" class="form-label"></label>
            <input asp-for="Input.Password" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary">Reset password</button>
    </form>
}

<partial name="_ValidationScriptsPartial" />
