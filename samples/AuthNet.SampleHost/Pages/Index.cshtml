@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="text-center">
    <h1 class="display-4">AuthNet Sample</h1>
    <p class="lead">Use this host to verify the built-in account, admin, and invitation pages.</p>

    <div class="d-flex flex-wrap justify-content-center gap-2">
        <a class="btn btn-primary" href="/auth/login">Sign in</a>
        <a class="btn btn-outline-secondary" href="/auth/register">Register</a>
        <a class="btn btn-outline-secondary" href="/auth/profile">Profile</a>
        <a class="btn btn-outline-dark" asp-page="/Admin">Admin dashboard</a>
        <a class="btn btn-outline-dark" href="/auth/admin/audit">Audit events</a>
    </div>

    <hr class="my-4" />

    <div class="row g-3 text-start">
        <div class="col-md-6">
            <div class="border rounded p-3 h-100">
                <h2 class="h5">Admin users</h2>
                <p>List users, inspect account state, and manage fixed administrator access.</p>
                <a href="/auth/admin/users">Open user list</a>
                <span> · </span>
                <a href="/auth/admin/users/new">Create user</a>
                <span> · </span>
                <a href="/auth/admin/audit">Audit events</a>
            </div>
        </div>
        <div class="col-md-6">
            <div class="border rounded p-3 h-100">
                <h2 class="h5">Invitations</h2>
                <p>Create invitation links for users without enabling public registration.</p>
                <a href="/auth/admin/invitations">View invitations</a>
                <span> · </span>
                <a href="/auth/admin/invitations/new">Create invitation</a>
            </div>
        </div>
    </div>
</div>
