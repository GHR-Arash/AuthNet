@page
@{
    ViewData["Title"] = "SPA";
}

<div class="row g-4">
    <div class="col-lg-5">
        <h1 class="h3">SPA workflow</h1>
        <form id="loginForm" class="vstack gap-3 mb-4">
            <div>
                <label class="form-label" for="identifier">Email or user name</label>
                <input class="form-control" id="identifier" name="identifier" autocomplete="username" />
            </div>
            <div>
                <label class="form-label" for="password">Password</label>
                <input class="form-control" id="password" name="password" type="password" autocomplete="current-password" />
            </div>
            <div class="form-check">
                <input class="form-check-input" id="rememberMe" name="rememberMe" type="checkbox" />
                <label class="form-check-label" for="rememberMe">Remember me</label>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-primary" type="submit">Sign in</button>
                <button class="btn btn-outline-secondary" id="logoutButton" type="button">Sign out</button>
            </div>
        </form>

        <div class="d-flex flex-wrap gap-2">
            <button class="btn btn-outline-dark" id="sessionButton" type="button">Load session</button>
            <button class="btn btn-outline-dark" id="profileButton" type="button">Load profile</button>
            <button class="btn btn-outline-dark" id="externalProvidersButton" type="button">External providers</button>
            <a class="btn btn-outline-dark" href="/auth/api/openapi.json">OpenAPI</a>
        </div>

        <hr class="my-4" />

        <form id="profileForm" class="vstack gap-3 mb-4">
            <h2 class="h5 mb-0">Profile</h2>
            <div>
                <label class="form-label" for="displayName">Display name</label>
                <input class="form-control" id="displayName" name="displayName" autocomplete="name" />
            </div>
            <div>
                <label class="form-label" for="phoneNumber">Phone number</label>
                <input class="form-control" id="phoneNumber" name="phoneNumber" autocomplete="tel" />
            </div>
            <button class="btn btn-outline-primary align-self-start" type="submit">Update profile</button>
        </form>

        <form id="changePasswordForm" class="vstack gap-3 mb-4">
            <h2 class="h5 mb-0">Change password</h2>
            <div>
                <label class="form-label" for="currentPassword">Current password</label>
                <input class="form-control" id="currentPassword" name="currentPassword" type="password" autocomplete="current-password" />
            </div>
            <div>
                <label class="form-label" for="newPassword">New password</label>
                <input class="form-control" id="newPassword" name="newPassword" type="password" autocomplete="new-password" />
            </div>
            <button class="btn btn-outline-primary align-self-start" type="submit">Change password</button>
        </form>

        <form id="externalLoginForm" class="vstack gap-3 mb-4">
            <h2 class="h5 mb-0">External login</h2>
            <div>
                <label class="form-label" for="externalProvider">Provider</label>
                <input class="form-control" id="externalProvider" name="externalProvider" value="AuthNetOidc" />
            </div>
            <div>
                <label class="form-label" for="externalReturnUrl">Return URL</label>
                <input class="form-control" id="externalReturnUrl" name="externalReturnUrl" value="/Spa" />
            </div>
            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-outline-primary" type="submit">Start sign in</button>
                <button class="btn btn-outline-secondary" id="externalLinkButton" type="button">Link provider</button>
            </div>
        </form>

        <div class="vstack gap-3">
            <h2 class="h5 mb-0">MFA</h2>
            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-outline-dark" id="mfaStatusButton" type="button">MFA status</button>
                <button class="btn btn-outline-dark" id="mfaSetupStartButton" type="button">Start setup</button>
                <button class="btn btn-outline-dark" id="mfaDisableButton" type="button">Disable MFA</button>
            </div>
            <form id="mfaSetupVerifyForm" class="vstack gap-3">
                <div>
                    <label class="form-label" for="mfaSetupCode">Setup code</label>
                    <input class="form-control" id="mfaSetupCode" name="mfaSetupCode" autocomplete="one-time-code" />
                </div>
                <button class="btn btn-outline-primary align-self-start" type="submit">Verify setup</button>
            </form>
            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-outline-dark" id="recoveryCodesButton" type="button">Recovery count</button>
                <button class="btn btn-outline-dark" id="regenerateRecoveryCodesButton" type="button">Regenerate codes</button>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <h2 class="h5">JSON response</h2>
        <pre id="output" class="border rounded p-3 bg-light text-break" style="min-height: 18rem;"></pre>

        <div class="row g-4 mt-1">
            <div class="col-md-6">
                <form id="resetPasswordForm" class="vstack gap-3">
                    <h2 class="h5 mb-0">Reset password</h2>
                    <div>
                        <label class="form-label" for="resetEmail">Email</label>
                        <input class="form-control" id="resetEmail" name="resetEmail" autocomplete="email" />
                    </div>
                    <div>
                        <label class="form-label" for="resetCode">Code</label>
                        <input class="form-control" id="resetCode" name="resetCode" />
                    </div>
                    <div>
                        <label class="form-label" for="resetPassword">New password</label>
                        <input class="form-control" id="resetPassword" name="resetPassword" type="password" autocomplete="new-password" />
                    </div>
                    <button class="btn btn-outline-primary align-self-start" type="submit">Reset password</button>
                </form>
            </div>
            <div class="col-md-6">
                <form id="confirmEmailForm" class="vstack gap-3">
                    <h2 class="h5 mb-0">Confirm email</h2>
                    <div>
                        <label class="form-label" for="confirmUserId">User ID</label>
                        <input class="form-control" id="confirmUserId" name="confirmUserId" />
                    </div>
                    <div>
                        <label class="form-label" for="confirmCode">Code</label>
                        <input class="form-control" id="confirmCode" name="confirmCode" />
                    </div>
                    <button class="btn btn-outline-primary align-self-start" type="submit">Confirm email</button>
                </form>
            </div>
        </div>

        <div class="row g-4 mt-1">
            <div class="col-md-6">
                <form id="mfaLoginForm" class="vstack gap-3">
                    <h2 class="h5 mb-0">MFA sign in</h2>
                    <div>
                        <label class="form-label" for="mfaLoginCode">Authenticator code</label>
                        <input class="form-control" id="mfaLoginCode" name="mfaLoginCode" autocomplete="one-time-code" />
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" id="mfaRememberMe" name="mfaRememberMe" type="checkbox" />
                        <label class="form-check-label" for="mfaRememberMe">Remember me</label>
                    </div>
                    <button class="btn btn-outline-primary align-self-start" type="submit">Complete sign in</button>
                </form>
            </div>
            <div class="col-md-6">
                <form id="recoveryCodeLoginForm" class="vstack gap-3">
                    <h2 class="h5 mb-0">Recovery sign in</h2>
                    <div>
                        <label class="form-label" for="recoveryLoginCode">Recovery code</label>
                        <input class="form-control" id="recoveryLoginCode" name="recoveryLoginCode" autocomplete="one-time-code" />
                    </div>
                    <button class="btn btn-outline-primary align-self-start" type="submit">Use recovery code</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const output = document.getElementById('output');

        async function api(path, options = {}) {
            const response = await fetch(path, {
                credentials: 'same-origin',
                headers: {
                    'Content-Type': 'application/json',
                    ...(options.headers || {})
                },
                ...options
            });
            const contentType = response.headers.get('content-type') || '';
            const body = contentType.includes('application/json')
                ? await response.json()
                : await response.text();
            output.textContent = JSON.stringify({
                status: response.status,
                body
            }, null, 2);
        }

        document.getElementById('loginForm').addEventListener('submit', async event => {
            event.preventDefault();
            await api('/auth/api/login', {
                method: 'POST',
                body: JSON.stringify({
                    identifier: document.getElementById('identifier').value,
                    password: document.getElementById('password').value,
                    rememberMe: document.getElementById('rememberMe').checked
                })
            });
        });

        document.getElementById('logoutButton').addEventListener('click', async () => {
            await api('/auth/api/logout', {
                method: 'POST',
                body: '{}'
            });
        });

        document.getElementById('sessionButton').addEventListener('click', async () => {
            await api('/auth/api/session');
        });

        document.getElementById('profileButton').addEventListener('click', async () => {
            await api('/auth/api/profile');
        });

        document.getElementById('externalProvidersButton').addEventListener('click', async () => {
            await api('/auth/api/external-providers');
        });

        document.getElementById('profileForm').addEventListener('submit', async event => {
            event.preventDefault();
            await api('/auth/api/profile', {
                method: 'PUT',
                body: JSON.stringify({
                    displayName: document.getElementById('displayName').value || null,
                    phoneNumber: document.getElementById('phoneNumber').value || null
                })
            });
        });

        document.getElementById('changePasswordForm').addEventListener('submit', async event => {
            event.preventDefault();
            await api('/auth/api/change-password', {
                method: 'POST',
                body: JSON.stringify({
                    currentPassword: document.getElementById('currentPassword').value,
                    newPassword: document.getElementById('newPassword').value
                })
            });
        });

        document.getElementById('externalLoginForm').addEventListener('submit', async event => {
            event.preventDefault();
            await api('/auth/api/external-login/challenge', {
                method: 'POST',
                body: JSON.stringify({
                    provider: document.getElementById('externalProvider').value,
                    returnUrl: document.getElementById('externalReturnUrl').value
                })
            });
        });

        document.getElementById('externalLinkButton').addEventListener('click', async () => {
            await api('/auth/api/external-login/link/challenge', {
                method: 'POST',
                body: JSON.stringify({
                    provider: document.getElementById('externalProvider').value,
                    returnUrl: document.getElementById('externalReturnUrl').value
                })
            });
        });

        document.getElementById('resetPasswordForm').addEventListener('submit', async event => {
            event.preventDefault();
            await api('/auth/api/reset-password', {
                method: 'POST',
                body: JSON.stringify({
                    email: document.getElementById('resetEmail').value,
                    code: document.getElementById('resetCode').value,
                    password: document.getElementById('resetPassword').value
                })
            });
        });

        document.getElementById('confirmEmailForm').addEventListener('submit', async event => {
            event.preventDefault();
            await api('/auth/api/confirm-email', {
                method: 'POST',
                body: JSON.stringify({
                    userId: document.getElementById('confirmUserId').value,
                    code: document.getElementById('confirmCode').value
                })
            });
        });

        document.getElementById('mfaStatusButton').addEventListener('click', async () => {
            await api('/auth/api/mfa');
        });

        document.getElementById('mfaSetupStartButton').addEventListener('click', async () => {
            await api('/auth/api/mfa/setup/start', {
                method: 'POST',
                body: '{}'
            });
        });

        document.getElementById('mfaSetupVerifyForm').addEventListener('submit', async event => {
            event.preventDefault();
            await api('/auth/api/mfa/setup/verify', {
                method: 'POST',
                body: JSON.stringify({
                    code: document.getElementById('mfaSetupCode').value
                })
            });
        });

        document.getElementById('mfaDisableButton').addEventListener('click', async () => {
            await api('/auth/api/mfa/disable', {
                method: 'POST',
                body: '{}'
            });
        });

        document.getElementById('recoveryCodesButton').addEventListener('click', async () => {
            await api('/auth/api/mfa/recovery-codes');
        });

        document.getElementById('regenerateRecoveryCodesButton').addEventListener('click', async () => {
            await api('/auth/api/mfa/recovery-codes/regenerate', {
                method: 'POST',
                body: '{}'
            });
        });

        document.getElementById('mfaLoginForm').addEventListener('submit', async event => {
            event.preventDefault();
            await api('/auth/api/login/mfa', {
                method: 'POST',
                body: JSON.stringify({
                    code: document.getElementById('mfaLoginCode').value,
                    rememberMe: document.getElementById('mfaRememberMe').checked
                })
            });
        });

        document.getElementById('recoveryCodeLoginForm').addEventListener('submit', async event => {
            event.preventDefault();
            await api('/auth/api/login/recovery-code', {
                method: 'POST',
                body: JSON.stringify({
                    recoveryCode: document.getElementById('recoveryLoginCode').value
                })
            });
        });

        api('/auth/api/session');
    </script>
}
